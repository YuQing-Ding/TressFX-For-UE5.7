+static int32 GTressFXFastResolveVelocityThreshold = 1;
+static FAutoConsoleVariableRef CVarTressFXFastResolveVelocityThreshold(TEXT("r.TressFX.VelocityThreshold"), GTressFXFastResolveVelocityThreshold, TEXT("Threshold value (in pixel) above which a pixel is forced to be resolve with responsive AA (in order to avoid smearing). Default is 3."));
+
+
+float GetTressFXFastResolveVelocityThreshold(const FIntPoint& Resolution)
+{
+	FVector2D PixelVelocity(1.f / (Resolution.X * 2), 1.f / (Resolution.Y * 2));
+	const float VelocityThreshold = FMath::Clamp(GTressFXFastResolveVelocityThreshold, 0, 512) * FMath::Min(PixelVelocity.X, PixelVelocity.Y);
+	return VelocityThreshold;
+}
