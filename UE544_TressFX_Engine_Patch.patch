+	static uint32 ToLinearIndex(uint32 HairCountIndex, uint32 HairRadiusIndex)
+	{
+		check(HairCountIndex < FHairCountToCoverageData::HairCount);
+		check(HairRadiusIndex < FHairCountToCoverageData::HairRadiusCount);
+		return HairRadiusIndex + HairCountIndex * FHairCountToCoverageData::HairRadiusCount;
+	}
+}; 
+
+static bool InternalTressFXLUT_NeedUpdateDualScatteringLUT(EShaderPlatform Platform)
+{
+	const FIntVector LUT3DResolution = FIntVector(GTressFXLUTIncidentAngleCount, GTressFXLUTRoughnessCount, GTressFXLUTAbsorptionCount);
+	return
+		(GSystemTextures.HairLUT0.GetReference() == nullptr ||
+			GSystemTextures.HairLUT0.GetReference()->GetRHI()->GetSizeXYZ() != LUT3DResolution) &&
+		(!IsHairMobilePlatform(Platform) && (IsTressFXSupported(ETressFXShaderType::Strands, Platform)));
+}
+
+static bool InternalTressFXLUT_NeedUpdateMeanEnergyLUT(EShaderPlatform Platform)
+{
+	const FIntVector LUT3DResolution = FIntVector(GTressFXLUTIncidentAngleCount, GTressFXLUTRoughnessCount, GTressFXLUTAbsorptionCount);
+	return
+		(GSystemTextures.HairLUT1.GetReference() == nullptr ||
+			GSystemTextures.HairLUT1.GetReference()->GetRHI()->GetSizeXYZ() != LUT3DResolution) &&
+		IsTressFXSupported(ETressFXShaderType::Strands, Platform);
+}
+
+static bool InternalTressFXLUT_NeedUpdateCoverageLUT(EShaderPlatform Platform)
+{
+	const FIntVector LUT2DResolution = FIntVector(FHairCountToCoverageData::HairCount, FHairCountToCoverageData::HairRadiusCount, 1);
+	return
+		(GSystemTextures.HairLUT2.GetReference() == nullptr ||
+			GSystemTextures.HairLUT2.GetReference()->GetRHI()->GetSizeXYZ() != LUT2DResolution) &&
+		IsTressFXSupported(ETressFXShaderType::Strands, Platform);
+}
+
+static FTressFXLUT InternalTressFXLUT_UpdateTressFXLUT(FRDGBuilder& GraphBuilder, const FViewInfo& View)
+{
+	const EShaderPlatform Platform = View.GetShaderPlatform();
+	FTressFXLUT Out;
+
+	if (InternalTressFXLUT_NeedUpdateDualScatteringLUT(Platform))
+	{
+		FRDGTextureRef TressFXDualScatteringLUTTexture = AddTressFXLUTPass(GraphBuilder, View, TressFXLUTType_DualScattering);
+		GSystemTextures.HairLUT0 = ConvertToExternalAccessTexture(GraphBuilder, TressFXDualScatteringLUTTexture);
+		Out.Textures[TressFXLUTType_DualScattering] = TressFXDualScatteringLUTTexture;
+	}
+	else
+	{
+		Out.Textures[TressFXLUTType_DualScattering] = GraphBuilder.RegisterExternalTexture(GSystemTextures.HairLUT0, TEXT("TressFXLUTType_DualScattering"));
+	}
+
+	if (InternalTressFXLUT_NeedUpdateMeanEnergyLUT(Platform))
+	{
+		FRDGTextureRef TressFXMeanEnergyLUTTexture = AddTressFXLUTPass(GraphBuilder, View, TressFXLUTType_MeanEnergy);
+		GSystemTextures.HairLUT1 = ConvertToExternalAccessTexture(GraphBuilder, TressFXMeanEnergyLUTTexture);
+		Out.Textures[TressFXLUTType_MeanEnergy] = TressFXMeanEnergyLUTTexture;
+	}
+	else
+	{
+		Out.Textures[TressFXLUTType_MeanEnergy] = GraphBuilder.RegisterExternalTexture(GSystemTextures.HairLUT1, TEXT("TressFXLUTType_MeanEnergy"));
+	}
+
+
+	return Out;
+}
+
+FTressFXLUT GetTressFXLUT(FRDGBuilder& GraphBuilder, const FViewInfo& View)
+{
+	return InternalTressFXLUT_UpdateTressFXLUT(GraphBuilder, View);
+}
+
+
+void UpdateTressFXLUT(FRDGBuilder& GraphBuilder, const FViewInfo& View)
+{
+	if (GUsingNullRHI) { return; }
+
+	const EShaderPlatform Platform = View.GetShaderPlatform();
+
+	const bool bNeedUpdateLUTs =
+		InternalTressFXLUT_NeedUpdateDualScatteringLUT(Platform) ||
+		InternalTressFXLUT_NeedUpdateMeanEnergyLUT(Platform) /*||
+		InternalTressFXLUT_NeedUpdateCoverageLUT(Platform)*/;
+
+	if (bNeedUpdateLUTs)
+	{
+		InternalTressFXLUT_UpdateTressFXLUT(GraphBuilder, View);
+	}
+}
