+template <uint32 Quality, bool bUseTransmission, bool bUseSubPixel>
+class TOnePassPointShadowProjectionTFXPS : public FGlobalShader
+{
+	DECLARE_SHADER_TYPE(TOnePassPointShadowProjectionTFXPS, Global);
