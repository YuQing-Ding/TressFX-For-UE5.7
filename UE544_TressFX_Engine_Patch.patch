+static bool HasDeepShadowData(const FLightSceneInfo* LightSceneInfo, const FTressFXMacroGroupDatas& InDatas)
+{
+	for (const FTressFXMacroGroupData& MacroGroupData : InDatas.Datas)
+	{
+		for (const FTressFXDeepShadowData& DomData : MacroGroupData.DeepShadowDatas.Datas)
+		{
+			if (DomData.LightId == LightSceneInfo->Id)
+				return true;
+		}
+	}
+
+	return false;
+}
