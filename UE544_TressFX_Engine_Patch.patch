+ENGINE_API bool IsTressFXGeometrySupported(const EShaderPlatform Platform);
+
+bool IsTressFXSupported(ETressFXShaderType Type, EShaderPlatform Platform)
+{
+	// Important:
+	// ETressFXShaderType::All: Mobile is excluded as we don't need any interpolation/simulation code for this. It only do rigid transformation. 
+	//                              The runtime setting in these case are r.TressFX.Binding=0 & r.TressFX.Simulation=0
+	const bool bIsMobile = IsMobilePlatform(Platform) || Platform == SP_PCD3D_ES3_1;
+
+	switch (Type)
+	{
+	case ETressFXShaderType::Strands: return IsTressFXGeometrySupported(Platform);
+	case ETressFXShaderType::Tool:	  return (IsD3DPlatform(Platform) || IsVulkanPlatform(Platform)) && IsPCPlatform(Platform) && GetMaxSupportedFeatureLevel(Platform) >= ERHIFeatureLevel::SM5;
+	case ETressFXShaderType::All:	  return !bIsMobile;
+	}
+	return false;
+}
+
+bool IsTressFXEnabled(ETressFXShaderType Type, EShaderPlatform Platform)
+{
+	const int32 TressFXGlobalEnable = CVarTressFXGlobalEnable.GetValueOnAnyThread();
+	if (TressFXGlobalEnable <= 0) return false;
+
+	// Important:
+	// ETressFXShaderType::All: Mobile is excluded as we don't need any interpolation/simulation code for this. It only do rigid transformation. 
+	//                              The runtime setting in these case are r.TressFX.Binding=0 & r.TressFX.Simulation=0
+	const bool bIsMobile = Platform != EShaderPlatform::SP_NumPlatforms ? IsMobilePlatform(Platform) || Platform == SP_PCD3D_ES3_1 : false;
+	const int32 TressFXStrandsEnable = CVarTressFXStrandsEnable.GetValueOnAnyThread();
+	switch (Type)
+	{
+	case ETressFXShaderType::Strands:	return TressFXStrandsEnable > 0 && (Platform != EShaderPlatform::SP_NumPlatforms ? IsTressFXGeometrySupported(Platform) : true);
+
+#if PLATFORM_DESKTOP && PLATFORM_WINDOWS
+	case ETressFXShaderType::Tool:		return (TressFXStrandsEnable > 0);
+#else
+	case ETressFXShaderType::Tool:		return false;
+#endif
+	case ETressFXShaderType::All:		return TressFXGlobalEnable > 0 && (TressFXStrandsEnable > 0) && !bIsMobile;
+	}
+	return false;
+}
+
+FTressFXBookmarkParameters CreateTressFXBookmarkParameters(FViewInfo& View, FScene* InScene)
+{
+	FTressFXBookmarkParameters Out;
+	//Out.DebugShaderData = &View.ShaderDrawData;
+	
+	Out.WorldType = View.Family->Scene->GetWorld()->WorldType;
+	Out.WorldName = View.Family->Scene->GetWorld()->GetName();
+	Out.SkinCache = View.Family->Scene->GetGPUSkinCache();
+	Out.ShaderMap = View.ShaderMap;
+	Out.View = &View;
+	Out.ViewRect = View.ViewRect;
+	Out.GPUScenePrimitiveBuffer = &InScene->GPUScene.PrimitiveBuffer;
+	Out.SceneColorTexture = nullptr;
+	Out.bStrandsGeometryEnabled = IsTressFXEnabled(ETressFXShaderType::Strands, View.GetShaderPlatform());
+	if (GTressFXParameterFunction)
+	{
+		GTressFXParameterFunction(Out);
+	}
+	Out.bHzbRequest = Out.bHasElements && Out.bStrandsGeometryEnabled;//&& IsTressFXClusterCullingUseHzb();
+
+	return Out;
+}
+
+FTressFXBookmarkParameters CreateTressFXBookmarkParameters(TArray<FViewInfo>& Views, FScene* InScene)
+{
+	FTressFXBookmarkParameters Out;
+	Out = CreateTressFXBookmarkParameters(Views[0],InScene);
+	Out.AllViews.Reserve(Views.Num());
+	for (const FViewInfo& View : Views)
+	{
+		Out.AllViews.Add(&View);
+	}
+
+	return Out;
+}
