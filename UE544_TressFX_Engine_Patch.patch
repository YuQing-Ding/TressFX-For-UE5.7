+extern TTressFXVisualizeSDFFunction GTressFXVisualizeSDFFunction;
+
+static void AddTressFXVisualizeSDFPass(
+	FRDGBuilder& GraphBuilder,
+	const FScene* Scene,
+	const FViewInfo& View,
+	FRDGTextureRef& InSceneColorTexture,
+	FRDGTextureRef& InSceneDepthTexture)
+{
+	if (!GTressFXVisualizeSDFFunction)
+		return;
+
+	FTressFXVisualizeSDFParameters VisualizeSDFParameters;
+	VisualizeSDFParameters.WorldType = Scene->GetWorld()->WorldType;
+	VisualizeSDFParameters.WorldName = Scene->GetWorld()->GetName();
+
+	GTressFXVisualizeSDFFunction(GraphBuilder, VisualizeSDFParameters);
+
+	if (!VisualizeSDFParameters.SDFBuffer)
+		return;
+
+	uint32 PointNum = VisualizeSDFParameters.NumSDFCells.X 
+		* VisualizeSDFParameters.NumSDFCells.Y
+		* VisualizeSDFParameters.NumSDFCells.Z;
+
+	const uint32 MaxPointNum = 62500;
+	uint32 Num = PointNum / MaxPointNum;
+	if (PointNum % MaxPointNum)
+		Num += 1;
+
+	TShaderMapRef<FTressFXVisualizeSDFMS> MeshShader(View.ShaderMap);
+	TShaderMapRef<FTressFXVisualizeSDFPS> PixelShader(View.ShaderMap);
+	const FGlobalShaderMap* GlobalShaderMap = View.ShaderMap;
+	const FIntRect Viewport = View.ViewRect;
+
+	for (uint32 i = 0; i < Num; ++i)
+	{
+		uint32 CurrentPointNum = MaxPointNum;
+		if (CurrentPointNum > PointNum)
+			CurrentPointNum = PointNum;
+		else
+			PointNum -= MaxPointNum;
+		FTressFXVisualizeSDFMS::FParameters* Parameters = GraphBuilder.AllocParameters<FTressFXVisualizeSDFMS::FParameters>();
+		Parameters->View = View.ViewUniformBuffer;
+		Parameters->NumSDFCells = VisualizeSDFParameters.NumSDFCells;
+		Parameters->PointOffset = i * MaxPointNum;
+		Parameters->CMBoxBuffer = VisualizeSDFParameters.CMBoxBuffer;
+		Parameters->SDFBufferR = VisualizeSDFParameters.SDFBuffer;
+		Parameters->SDFDirectionStartOffsetBufferR = VisualizeSDFParameters.SDFDirectionStartOffsetBuffer;
+		Parameters->SDFDirectionBufferR = VisualizeSDFParameters.SDFDirectionBuffer;
+		Parameters->RenderTargets[0] = FRenderTargetBinding(InSceneColorTexture, ERenderTargetLoadAction::ELoad, 0);
+		Parameters->RenderTargets.DepthStencil = FDepthStencilBinding(
+			InSceneDepthTexture,
+			ERenderTargetLoadAction::ELoad,
+			ERenderTargetLoadAction::ENoAction,
+			FExclusiveDepthStencil::DepthWrite_StencilNop);
+
+		{
+			ClearUnusedGraphResources(MeshShader, Parameters);
+
+			GraphBuilder.AddPass(
+				RDG_EVENT_NAME("TressFXVisualizeSDF"),
+				Parameters,
+				ERDGPassFlags::Raster | ERDGPassFlags::NeverCull,
+				[Parameters, CurrentPointNum, MeshShader, PixelShader, Viewport](FRHICommandList& RHICmdList)
+				{
+					FGraphicsPipelineStateInitializer GraphicsPSOInit;
+					RHICmdList.ApplyCachedRenderTargets(GraphicsPSOInit);
+					GraphicsPSOInit.BlendState = TStaticBlendState<CW_RGBA, BO_Add, BF_One, BF_Zero, BO_Add, BF_One, BF_Zero>::GetRHI();
+					GraphicsPSOInit.RasterizerState = TStaticRasterizerState<>::GetRHI();
+					GraphicsPSOInit.DepthStencilState = TStaticDepthStencilState<true, CF_GreaterEqual>::GetRHI();
+
+					GraphicsPSOInit.BoundShaderState.VertexDeclarationRHI = nullptr;
+
+					GraphicsPSOInit.BoundShaderState.SetMeshShader(MeshShader.GetMeshShader());
+					GraphicsPSOInit.BoundShaderState.PixelShaderRHI = PixelShader.GetPixelShader();
+					GraphicsPSOInit.PrimitiveType = PT_PointList;
+					SetGraphicsPipelineState(RHICmdList, GraphicsPSOInit, 0); 
+
+					SetShaderParameters(RHICmdList, MeshShader, MeshShader.GetMeshShader(), *Parameters);
+
+					{
+						RHICmdList.SetViewport(Viewport.Min.X, Viewport.Min.Y, 0.0f, Viewport.Max.X, Viewport.Max.Y, 1.0f);
+
+						RHICmdList.DispatchMeshShader(CurrentPointNum, 1, 1);
+					}
+				});
+		}
+	}
+}
