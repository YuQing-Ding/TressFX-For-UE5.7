+
+		InterlockedAdd(DrawIndirectParameters[0], CurrentActiveStrandsCount * NumVerticesPerStrand * 6);
+		//if(0 == ClusterId)
+			//DrawIndirectParameters[0] = CurrentActiveStrandsCount * 16 * 6;
+	}
+}
