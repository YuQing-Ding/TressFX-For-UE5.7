+
+void RenderTressFXSDFMesh(
+	FRDGBuilder& GraphBuilder,
+	FScene* Scene,
+	FSceneTextures& SceneTextures,
+	TArray<FViewInfo>& Views)
+{
+	RDG_EVENT_SCOPE(GraphBuilder, "VisualizeTressFXSDF");
+
+	AddTressFXVisualizeSDFMeshPass(
+		GraphBuilder,
+		Scene,
+		Views[0],
+		SceneTextures.Color.Target,
+		SceneTextures.Depth.Target);
+
+	if (!GRHISupportsMeshShadersTier0)
+		return;
+
+	AddTressFXVisualizeSDFMeshAABBPass(
+		GraphBuilder,
+		Scene,
+		Views[0],
+		SceneTextures.Color.Target,
+		SceneTextures.Depth.Target);
+
+	AddTressFXVisualizeSDFPass(
+		GraphBuilder,
+		Scene,
+		Views[0],
+		SceneTextures.Color.Target,
+		SceneTextures.Depth.Target);
+
+}
