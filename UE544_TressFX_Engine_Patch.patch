+
+static FRasterComputeOutput AddVisibilityComputeRasterPass(
+	FRDGBuilder& GraphBuilder,
+	const FViewInfo& ViewInfo,
+	const FIntPoint& InResolution,
+	const uint32 SamplePerPixelCount,
+	const FRDGTextureRef SceneDepthTexture)
+{
+	check(DoesSupportRasterCompute());
+
+	FRasterComputeOutput Out;
+
+	const uint32 GroupSize = 32;
+	const uint32 DispatchCountX = 64;
+
+	FTressFXVisiblityRasterComputeCS::FPermutationDomain PermutationVector0;
+	FTressFXVisiblityRasterComputeCS::FPermutationDomain PermutationVector1;
+#if PLATFORM_WINDOWS
+	if (IsRHIDeviceNVIDIA())
+	{
+		PermutationVector0.Set<FTressFXVisiblityRasterComputeCS::FRasterAtomic>(1);
+	}
+	else if (IsRHIDeviceAMD())
+	{
+		static const bool bIsDx12 = FCString::Strcmp(GDynamicRHI->GetName(), TEXT("D3D12")) == 0;
+		PermutationVector0.Set<FTressFXVisiblityRasterComputeCS::FRasterAtomic>(bIsDx12 ? 2 : 3);
+	}
+#else
+	{
+		PermutationVector0.Set<FVisiblityRasterComputeCS::FRasterAtomic>(0);
+	}
+#endif
+	PermutationVector0.Set<FTressFXVisiblityRasterComputeCS::FSPP>(SamplePerPixelCount);
+	PermutationVector1 = PermutationVector0;
+
+	PermutationVector0.Set<FTressFXVisiblityRasterComputeCS::FCulling>(0);
+	PermutationVector1.Set<FTressFXVisiblityRasterComputeCS::FCulling>(1);
+	TShaderMapRef<FTressFXVisiblityRasterComputeCS> ComputeShader_CullingOff(ViewInfo.ShaderMap, PermutationVector0);
+	TShaderMapRef<FTressFXVisiblityRasterComputeCS> ComputeShader_CullingOn(ViewInfo.ShaderMap, PermutationVector1);
+
+
+	{
+		FTressFXVisiblityRasterComputeCS::FParameters* PassParameters = GraphBuilder.AllocParameters<FTressFXVisiblityRasterComputeCS::FParameters>();
+
+		{
+			const uint32 DispatchCountY = FMath::CeilToInt(PassParameters->TressFXVF_VertexCount / float(GroupSize * DispatchCountX));
+			const FIntVector DispatchCount(DispatchCountX, DispatchCountY, 1);
+			FComputeShaderUtils::AddPass(GraphBuilder, RDG_EVENT_NAME("TressFXVisibilityComputeRaster(culling=off)"), ComputeShader_CullingOff, PassParameters, DispatchCount);
+		}
+	}
+
+	return Out;
+}
+*/
