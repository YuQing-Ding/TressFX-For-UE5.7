+const TCHAR* ToString(FTressFXTiles::ETileType Type)
+{
+	switch (Type)
+	{
+	case FTressFXTiles::ETileType::TfxHairAll:			return TEXT("TfxHair(All)");
+	case FTressFXTiles::ETileType::TfxHairFull:		return TEXT("TfxHair(Full)");
+	case FTressFXTiles::ETileType::TfxHairPartial:		return TEXT("TfxHair(Partial)");
