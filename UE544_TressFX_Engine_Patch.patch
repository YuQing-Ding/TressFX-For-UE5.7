+	FScene* Scene,
+	TArray<FViewInfo>& Views,
+	FTressFXRenderingData& OutHairDatas,
+	FInstanceCullingManager& InstanceCullingManager)
+{
+	RDG_EVENT_SCOPE(GraphBuilder, "TressFXPrePass");
+
+	CreateTressFXMacroGroups(GraphBuilder, Scene, Views);
+	
+	RenderTressFXDeepShadows(GraphBuilder, Scene, Views, InstanceCullingManager);
+
+}
+
+void RenderTressFXBasePass(
+	FRDGBuilder& GraphBuilder,
+	FScene* Scene,
+	FSceneTextures& SceneTextures,
+	TArray<FViewInfo>& Views,
+	FTressFXRenderingData& OutHairDatas,
+	FInstanceCullingManager& InstanceCullingManager)
+{
+
+	RDG_EVENT_SCOPE(GraphBuilder, "TressFXBasePass");
+	// #hair_todo: Add multi-view
+	const bool bIsViewCompatible = Views.Num() > 0 && IsTressFXEnabled(ETressFXShaderType::Strands, Views[0].GetShaderPlatform());
+	if (bIsViewCompatible)
+	{
+		const ERHIFeatureLevel::Type FeatureLevel = Scene->GetFeatureLevel();
+
+		// TressFX visibility pass
+		RenderTressFXVisibilityBuffer(
+			GraphBuilder,
+			Scene,
+			Views,
+			SceneTextures.GBufferA,
+			SceneTextures.GBufferB,
+			SceneTextures.GBufferC,
+			SceneTextures.GBufferD,
+			SceneTextures.GBufferE,
+			SceneTextures.Color.Target,
+			SceneTextures.Depth.Target,
+			SceneTextures.Velocity,
+			InstanceCullingManager);
+	}
+}
