+
+#include "../Common.ush"
+#include "TressFXSimulationSDFCommon.ush"
+#include "/Engine/Private/SceneData.ush"
+
+uint PrimitiveId;
+
+
+
+uint FloatFlip(float fl)
+{
+	uint f = asuint(fl);
+	return f ^ 0x80000000;
+}
+
+struct FTressFXMeshVertexData
+{
+	float4 Position;
+	float4 Normal;
+};
+StructuredBuffer<FTressFXMeshVertexData>		MeshRestVertexBuffer;
+
+RWStructuredBuffer<FTressFXMeshVertexData>		MeshDeformedVertexBuffer;
+
+uint NumMeshVertices;
+
+struct FBoneSkinningData
+{
+	uint BoneIndex;  
+	float BoneWeight; 
+};
+
+struct FBoneIndexData
+{
+	uint StartIndex;  
+	uint Count; 
+};
+
+
+StructuredBuffer<FBoneSkinningData> BoneSkinningBuffer;
+StructuredBuffer<FBoneIndexData> BoneIndexBuffer;
+StructuredBuffer<float4> BoneMatricesBuffer;
+
+struct FIntermediateCollisionMeshBox
+{
+	int4 Max;
+	int4 Min;
+};
+
+globallycoherent RWStructuredBuffer<FIntermediateCollisionMeshBox> ICMBox;
+
+groupshared FIntermediateCollisionMeshBox LDS_ICMBox;
+
+groupshared FTressFXMeshVertexData LDS_MeshVertexData[THREAD_GROUP_SIZE];
+groupshared FBoneIndexData LDS_BoneIndexData[THREAD_GROUP_SIZE];
+groupshared FBoneSkinningData LDS_BoneSkinningData[THREAD_GROUP_SIZE];
+groupshared float4 A[THREAD_GROUP_SIZE];
+groupshared float4 B[THREAD_GROUP_SIZE];
+groupshared float4 C[THREAD_GROUP_SIZE];
+groupshared float4 D[THREAD_GROUP_SIZE];
+
+[numthreads(THREAD_GROUP_SIZE,1,1)]
+void SDFMeshSkinning(
+	uint GIndex : SV_GroupIndex, 
+	uint3 GId : SV_GroupID, 
+	uint3 DTid : SV_DispatchThreadID)
+{
+	uint LocalId = GIndex;
+	uint GroupId = GId.x;
+	uint GlobalId = LocalId + GroupId * THREAD_GROUP_SIZE;
+
+	GlobalId = GlobalId >= NumMeshVertices ? NumMeshVertices-1 : GlobalId;
+
+	LDS_MeshVertexData[LocalId] = MeshRestVertexBuffer[GlobalId];
+
+	// compute a bone skinning transform
+	
+	LDS_BoneIndexData[LocalId] = BoneIndexBuffer[GlobalId];
+	LDS_BoneSkinningData[LocalId] = BoneSkinningBuffer[LDS_BoneIndexData[LocalId].StartIndex];
+
+	// Interpolate world space bone matrices using weights. 
+	uint BoneIndex = LDS_BoneSkinningData[LocalId].BoneIndex;
+	A[LocalId] = BoneMatricesBuffer[4*BoneIndex];
+	B[LocalId] = BoneMatricesBuffer[4*BoneIndex+1];
+	C[LocalId] = BoneMatricesBuffer[4*BoneIndex+2];
+	D[LocalId] = BoneMatricesBuffer[4*BoneIndex+3];
+    float4x4 BoneMatrix = float4x4(A[LocalId],B[LocalId],C[LocalId],D[LocalId]) * LDS_BoneSkinningData[LocalId].BoneWeight;
+	float WeightSum = LDS_BoneSkinningData[LocalId].BoneWeight;
+
+	// Each vertex gets influence from four bones. In case there are less than four bones, boneIndex and boneWeight would be zero. 
+	// This number four was set in Maya exporter and also used in loader. So it should not be changed unless you have a very strong reason and are willing to go through all spots. 
+	for (int i = 1; i < LDS_BoneIndexData[LocalId].Count; i++)
+	{
+		LDS_BoneSkinningData[LocalId] = BoneSkinningBuffer[LDS_BoneIndexData[LocalId].StartIndex+i];
+		if (LDS_BoneSkinningData[LocalId].BoneWeight > 0)
+		{
+			BoneIndex = LDS_BoneSkinningData[LocalId].BoneIndex;
+			A[LocalId] = BoneMatricesBuffer[4*BoneIndex];
+			B[LocalId] = BoneMatricesBuffer[4*BoneIndex+1];
+			C[LocalId] = BoneMatricesBuffer[4*BoneIndex+2];
+			D[LocalId] = BoneMatricesBuffer[4*BoneIndex+3];
+            BoneMatrix += float4x4(A[LocalId],B[LocalId],C[LocalId],D[LocalId]) * LDS_BoneSkinningData[LocalId].BoneWeight;
+			WeightSum += LDS_BoneSkinningData[LocalId].BoneWeight;
+		}
+	}
+
+	BoneMatrix /= WeightSum;
+	
+	// Local To World
+	FPrimitiveSceneData PrimitiveData = GetPrimitiveData(PrimitiveId);
+	float4x4 LocalToWorld = DFDemote(PrimitiveData.LocalToWorld);
+	BoneMatrix = mul(BoneMatrix,LocalToWorld);
+
+	LDS_MeshVertexData[LocalId].Position = mul(float4(LDS_MeshVertexData[LocalId].Position.xyz, 1), BoneMatrix);
+	LDS_MeshVertexData[LocalId].Normal = mul(float4(LDS_MeshVertexData[LocalId].Normal.xyz, 0), BoneMatrix);
+	MeshDeformedVertexBuffer[GlobalId].Position = float4(LDS_MeshVertexData[LocalId].Position.xyz,0);
+	MeshDeformedVertexBuffer[GlobalId].Normal = float4(LDS_MeshVertexData[LocalId].Normal.xyz,0);
+
+	if(0 == GIndex)
+	{
+		LDS_ICMBox.Min = int4(0x7FFFFFFF,0x7FFFFFFF,0x7FFFFFFF,0);
+		LDS_ICMBox.Max = -int4(0x7FFFFFFF,0x7FFFFFFF,0x7FFFFFFF,0);
+	}
+	GroupMemoryBarrierWithGroupSync();
+
+	int3 IntPos = LDS_MeshVertexData[LocalId].Position.xyz;
+
+	InterlockedMax(LDS_ICMBox.Max.x,IntPos.x);
+	InterlockedMin(LDS_ICMBox.Min.x,IntPos.x);
+	InterlockedMax(LDS_ICMBox.Max.y,IntPos.y);
+	InterlockedMin(LDS_ICMBox.Min.y,IntPos.y);
+	InterlockedMax(LDS_ICMBox.Max.z,IntPos.z);
+	InterlockedMin(LDS_ICMBox.Min.z,IntPos.z);
+
+	GroupMemoryBarrierWithGroupSync();
+
+	if(0 == GIndex)
+	{
+		InterlockedMax(ICMBox[0].Max.x,LDS_ICMBox.Max.x);
+		InterlockedMin(ICMBox[0].Min.x,LDS_ICMBox.Min.x);
+		InterlockedMax(ICMBox[0].Max.y,LDS_ICMBox.Max.y);
+		InterlockedMin(ICMBox[0].Min.y,LDS_ICMBox.Min.y);
+		InterlockedMax(ICMBox[0].Max.z,LDS_ICMBox.Max.z);
+		InterlockedMin(ICMBox[0].Min.z,LDS_ICMBox.Min.z);
+	}
+
+}
+
+
+[numthreads(THREAD_GROUP_SIZE,1,1)]
+void SDFMeshSkinningNoBone(
+	uint GIndex : SV_GroupIndex, 
+	uint3 GId : SV_GroupID, 
+	uint3 DTid : SV_DispatchThreadID)
+{
+	uint LocalId = GIndex;
+	uint GroupId = GId.x;
+	uint GlobalId = LocalId + GroupId * THREAD_GROUP_SIZE;
+
+	GlobalId = GlobalId >= NumMeshVertices ? NumMeshVertices-1 : GlobalId;
+
+	float3 Pos = MeshRestVertexBuffer[GlobalId].Position.xyz;
+
+	if(0 == GIndex)
+	{
+		LDS_ICMBox.Min = int4(0x7FFFFFFF,0x7FFFFFFF,0x7FFFFFFF,0);
+		LDS_ICMBox.Max = -int4(0x7FFFFFFF,0x7FFFFFFF,0x7FFFFFFF,0);
+	}
+	GroupMemoryBarrierWithGroupSync();
+	
+	int3 IntPos = Pos;
+
+	InterlockedMax(LDS_ICMBox.Max.x,IntPos.x);
+	InterlockedMin(LDS_ICMBox.Min.x,IntPos.x);
+	InterlockedMax(LDS_ICMBox.Max.y,IntPos.y);
+	InterlockedMin(LDS_ICMBox.Min.y,IntPos.y);
+	InterlockedMax(LDS_ICMBox.Max.z,IntPos.z);
+	InterlockedMin(LDS_ICMBox.Min.z,IntPos.z);
+
+
+	GroupMemoryBarrierWithGroupSync();
+
+	if(0 == GIndex)
+	{
+		InterlockedMax(ICMBox[0].Max.x,LDS_ICMBox.Max.x);
+		InterlockedMin(ICMBox[0].Min.x,LDS_ICMBox.Min.x);
+		InterlockedMax(ICMBox[0].Max.y,LDS_ICMBox.Max.y);
+		InterlockedMin(ICMBox[0].Min.y,LDS_ICMBox.Min.y);
+		InterlockedMax(ICMBox[0].Max.z,LDS_ICMBox.Max.z);
+		InterlockedMin(ICMBox[0].Min.z,LDS_ICMBox.Min.z);
+	}
+
+}
