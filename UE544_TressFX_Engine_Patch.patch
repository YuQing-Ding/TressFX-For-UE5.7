+static FRDGTextureRef AddTressFXLUTPass(
+	FRDGBuilder& GraphBuilder,
+	const FViewInfo& View,
+	const FTressFXLUTType LUTType)
+{
+	const FIntVector OutputResolution(GTressFXLUTIncidentAngleCount, GTressFXLUTRoughnessCount, GTressFXLUTAbsorptionCount);
+
+	FRDGTextureDesc OutputDesc;
+	OutputDesc.Dimension = ETextureDimension::Texture3D;
+	OutputDesc.Extent.X = OutputResolution.X;
+	OutputDesc.Extent.Y = OutputResolution.Y;
+	OutputDesc.Depth = OutputResolution.Z;
+	OutputDesc.Format = PF_FloatRGBA;
+	OutputDesc.NumMips = 1;
+	OutputDesc.Flags = TexCreate_ShaderResource | TexCreate_UAV;
+	FRDGTextureRef TressFXLUTTexture = GraphBuilder.CreateTexture(OutputDesc, TEXT("TressFXLUT"));
+
+	FTressFXLUTCS::FParameters* Parameters = GraphBuilder.AllocParameters<FTressFXLUTCS::FParameters>();
+	Parameters->OutputColor = GraphBuilder.CreateUAV(FRDGTextureUAVDesc(TressFXLUTTexture, 0));
+	Parameters->ThetaCount = OutputResolution.X;
+	Parameters->RoughnessCount = OutputResolution.Y;
+	Parameters->AbsorptionCount = OutputResolution.Z;
+	Parameters->SampleCountScale = GTressFXLUTSampleCountScale;
+	Parameters->OutputResolution = OutputResolution;
+
+	FTressFXLUTCS::FPermutationDomain PermutationVector;
+	PermutationVector.Set<FTressFXLUTCS::FLUTType>(LUTType);
+
+	TShaderMapRef<FTressFXLUTCS> ComputeShader(View.ShaderMap, PermutationVector);
+	FComputeShaderUtils::AddPass(
+		GraphBuilder,
+		RDG_EVENT_NAME("TressFXLUT"),
+		ERDGPassFlags::Compute | ERDGPassFlags::NeverCull,
+		ComputeShader,
+		Parameters,
+		FComputeShaderUtils::GetGroupCount(OutputResolution, FIntVector(FComputeShaderUtils::kGolden2DGroupSize)));
+
+	return TressFXLUTTexture;
+}
