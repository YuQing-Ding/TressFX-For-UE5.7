+}
+
+void CreateTressFXMacroGroups(
+	FRDGBuilder& GraphBuilder,
+	const FScene* Scene,
+	TArray<FViewInfo>& Views)
+{
+	static const FVertexFactoryType* CompatibleVF = FVertexFactoryType::GetVFByName(TEXT("FTressFXVertexFactory"));
+
+	FTressFXMacroGroupViews MacroGroupsViews;
+	for (int32 ViewIndex = 0; ViewIndex < Views.Num(); ViewIndex++)
+	{
+		FViewInfo& View = Views[ViewIndex];
+		if (View.Family)
+		{
+			int32 MaterialId = 0;
+			FTressFXMacroGroupDatas& MacroGroups = View.TressFXViewData.MacroGroupDatas;// MacroGroupsViews.Views.AddDefaulted_GetRef();
+
+			if (View.TressFXMeshElements.Num() == 0 || View.bIsPlanarReflection || View.bIsReflectionCapture)
+			{
+				continue;
+			}
+			// Aggregate all hair primitives within the same area into macro groups, for allocating/rendering DOM/voxel
+			uint32 MacroGroupId = 0;
+			auto UpdateMacroGroup = [&MacroGroups, &View, &MacroGroupId, &MaterialId](const FMeshBatchAndRelevance* MeshBatchAndRelevance, const FPrimitiveSceneProxy* Proxy)
+			{
+				const bool bIsTressFXFactory = MeshBatchAndRelevance->Mesh->VertexFactory->GetType()->GetHashedName() == CompatibleVF->GetHashedName();
+				if (!bIsTressFXFactory)
+					return;
+
+				const FBoxSphereBounds& OriginalPrimitiveBounds = Proxy->GetBounds();
+				FTressFXGroupPublicData* TressFXData = GetTressFXData(MeshBatchAndRelevance->Mesh);
+				FBoxSphereBounds PrimitiveBounds = OriginalPrimitiveBounds.ExpandBy(TressFXData->VFInput.Strands.MaxLength * 0.5f);
+
+				bool bFound = false;
+				for (FTressFXMacroGroupData& MacroGroup : MacroGroups.Datas)
+				{
+					const bool bIntersect = FBoxSphereBounds::SpheresIntersect(MacroGroup.Bounds, PrimitiveBounds);
+					if (bIntersect)
+					{
+						MacroGroup.Bounds = Union(MacroGroup.Bounds, PrimitiveBounds);
+						InternalUpdateMacroGroup(MacroGroup, MaterialId, MeshBatchAndRelevance, Proxy);
+						bFound = true;
+						break;
+					}
+				}
+
+				if (!bFound)
+				{
+					FTressFXMacroGroupData MacroGroup;
+					MacroGroup.MacroGroupId = MacroGroupId++;
+					InternalUpdateMacroGroup(MacroGroup, MaterialId, MeshBatchAndRelevance, Proxy);
+					MacroGroup.Bounds = PrimitiveBounds;
+					MacroGroups.Datas.Add(MacroGroup);
+				}
+			};
+
+			for (const FMeshBatchAndRelevance& MeshBatchAndRelevance : View.TressFXMeshElements)
+			{
+				UpdateMacroGroup(&MeshBatchAndRelevance, MeshBatchAndRelevance.PrimitiveSceneProxy);
+			}
+			
+			// Build hair macro group AABBB
+			const uint32 MacroGroupCount = MacroGroups.Datas.Num();
+			if (MacroGroupCount > 0)
+			{
+				View.TressFXViewData.bIsValid = true;
+
+				DECLARE_GPU_STAT(TressFXAABB);
+				RDG_EVENT_SCOPE(GraphBuilder, "TressFXAABB");
+				RDG_GPU_STAT_SCOPE(GraphBuilder, TressFXAABB);
+
+				MacroGroups.MacroGroupResources.MacroGroupAABBsBuffer = GraphBuilder.CreateBuffer(FRDGBufferDesc::CreateBufferDesc(4, 6 * MacroGroupCount), TEXT("TressFXMacroGroupAABBBuffer"));
+				FRDGBufferUAVRef MacroGroupAABBBufferUAV = GraphBuilder.CreateUAV(MacroGroups.MacroGroupResources.MacroGroupAABBsBuffer, PF_R32_SINT);
+				for (FTressFXMacroGroupData& MacroGroup : MacroGroups.Datas)
+				{
+					AddTressFXMacroGroupAABBPass(GraphBuilder, View, MacroGroup, MacroGroupAABBBufferUAV);
+				}
+				MacroGroups.MacroGroupResources.MacroGroupCount = MacroGroups.Datas.Num();
+			}
+		}
+	}
+
+	//return MacroGroupsViews;
+}
