+static FRDGBufferRef AddCopyIndirectArgPass(
+	FRDGBuilder& GraphBuilder,
+	const FViewInfo* View,
+	const uint32 ThreadGroupSize,
+	const uint32 ItemCountPerGroup,
+	FRDGTextureRef CounterTexture)
+{
+	check(CounterTexture);
+
+	FRDGBufferRef OutBuffer = GraphBuilder.CreateBuffer(FRDGBufferDesc::CreateIndirectDesc<FRHIDispatchIndirectParameters>(), TEXT("TressFXVisibilityIndirectArgBuffer"));
+
+	FCopyIndirectBufferTFXCS::FParameters* Parameters = GraphBuilder.AllocParameters<FCopyIndirectBufferTFXCS::FParameters>();
+	Parameters->ThreadGroupSize = ThreadGroupSize;
+	Parameters->ItemCountPerGroup = ItemCountPerGroup;
+	Parameters->CounterTexture = CounterTexture;
+	Parameters->OutArgBuffer = GraphBuilder.CreateUAV(OutBuffer);
+
+	TShaderMapRef<FCopyIndirectBufferTFXCS> ComputeShader(View->ShaderMap);
+
+	FComputeShaderUtils::AddPass(
+		GraphBuilder,
+		RDG_EVENT_NAME("TressFXVisbilityCopyIndirectArgs"),
+		ComputeShader,
+		Parameters,
+		FIntVector(1, 1, 1));
+
+	return OutBuffer;
+}
+
+
+static void AddTressFXVisibilityPrimitiveIdCompactionPass(
+	const bool bUsePPLL,
+	const bool bUseVisibility,
+	FRDGBuilder& GraphBuilder,
+	const FViewInfo& View,
+	const FRDGTextureRef& SceneDepthTexture,
+	const FTressFXMacroGroupDatas& MacroGroupDatas,
+	const uint32 NodeGroupSize,
+	const FTressFXTiles& TileData,
+	FTressFXVisibilityPrimitiveIdCompactionCS::FParameters* PassParameters,
+	FRDGTextureRef& OutTressFXOnlyDepthTexture,
+	FRDGTextureRef& OutCompactCounter,
+	FRDGTextureRef& OutCompactNodeIndex,
+	FRDGBufferRef& OutCompactNodeData,
+	FRDGBufferRef& OutCompactNodeCoord,
+	FRDGTextureRef& OutCategorizationTexture,
+	FRDGTextureRef& OutVelocityTexture,
+	FRDGBufferRef& OutIndirectArgsBuffer,
+	uint32& OutMaxRenderNodeCount)
+{
+	FIntPoint Resolution;
+
+	{
+		check(PassParameters->MSAA_DepthTexture->Desc.NumSamples == GetMaxSamplePerPixel());
+
+		if (bUseVisibility)
+		{
+			check(PassParameters->MSAA_DepthTexture);
+			check(PassParameters->MSAA_IDTexture);
+			Resolution = PassParameters->MSAA_DepthTexture->Desc.Extent;
+		}
+		else
+		{
+			check(PassParameters->MSAA_DepthTexture);
+			check(PassParameters->MSAA_IDTexture);
+			check(PassParameters->MSAA_MaterialTexture);
+			check(PassParameters->MSAA_AttributeTexture);
+			Resolution = PassParameters->MSAA_DepthTexture->Desc.Extent;
+		}
+	}
+
+
+	{
+		FRDGTextureDesc Desc = FRDGTextureDesc::Create2D(FIntPoint(1, 1), PF_R32_UINT, FClearValueBinding::Black, TexCreate_UAV | TexCreate_ShaderResource | TexCreate_RenderTargetable);
+		OutCompactCounter = GraphBuilder.CreateTexture(Desc, TEXT("TressFXVisibilityCompactCounter"));
+	}
+
+	{
+		FRDGTextureDesc Desc = FRDGTextureDesc::Create2D(Resolution, PF_R32_UINT, FClearValueBinding::None, TexCreate_UAV | TexCreate_ShaderResource | TexCreate_RenderTargetable);
+		OutCompactNodeIndex = GraphBuilder.CreateTexture(Desc, TEXT("TressFXVisibilityCompactNodeIndex"));
+	}
+
+	{
+		FRDGTextureDesc Desc = FRDGTextureDesc::Create2D(Resolution, PF_R16F, FClearValueBinding::Black, TexCreate_UAV | TexCreate_ShaderResource | TexCreate_RenderTargetable);
+		OutCategorizationTexture = GraphBuilder.CreateTexture(Desc, TEXT("TressFXCategorizationTexture"));
+	}
+
+	const uint32 ClearValues[4] = { 0u,0u,0u,0u };
+	AddClearRenderTargetPass(GraphBuilder, OutCompactCounter);
+	AddClearRenderTargetPass(GraphBuilder, OutCategorizationTexture);
+	AddClearGraphicPass(GraphBuilder, RDG_EVENT_NAME("NodeOffsetAndCount"), &View, 0, TileData, OutCompactNodeIndex);
+	//AddClearGraphicPass(GraphBuilder, RDG_EVENT_NAME("CategorizationTexture"), &View, 0, TileData, OutCategorizationTexture);
+	AddClearGraphicPass(GraphBuilder, RDG_EVENT_NAME("TressFXDepthOnlyTemp"), &View, 0, TileData, OutTressFXOnlyDepthTexture);
+
+	const uint32 MSAASampleCount = GetTressFXVisibilityRenderMode() == TressFXVisibilityRenderMode_MSAA ? GetMaxSamplePerPixel() : 1;
+	const uint32 PPLLMaxRenderNodePerPixel = GetMaxSamplePerPixel();
+	const uint32 MaxRenderNodeCount = GetTotalSampleCountForAllocation(Resolution);
+	OutCompactNodeData = GraphBuilder.CreateBuffer(FRDGBufferDesc::CreateStructuredDesc(bUseVisibility ? sizeof(TressFXVisibilityInternal::NodeVis) : sizeof(TressFXVisibilityInternal::NodeData), MaxRenderNodeCount), TEXT("TressFXVisibilityPrimitiveIdCompactNodeData"));
+
+	{
+		// Pixel coord of the node. Stored as 2*uint16, packed into a single uint32
+		OutCompactNodeCoord = GraphBuilder.CreateBuffer(FRDGBufferDesc::CreateStructuredDesc(sizeof(uint32), MaxRenderNodeCount), TEXT("TressFXVisibilityPrimitiveIdCompactNodeCoord"));
+	}
+
+	const bool bWriteOutVelocity = OutVelocityTexture != nullptr;
+	const uint32 VelocityPermutation = bWriteOutVelocity ? FMath::Clamp(GTressFXVelocityType + 1, 0, 3) : 0;
+	FTressFXVisibilityPrimitiveIdCompactionCS::FPermutationDomain PermutationVector;
+	PermutationVector.Set<FTressFXVisibilityPrimitiveIdCompactionCS::FGroupSize>(1);
+	PermutationVector.Set<FTressFXVisibilityPrimitiveIdCompactionCS::FVelocity>(VelocityPermutation > 0 ? 1 : 0);
+	PermutationVector.Set<FTressFXVisibilityPrimitiveIdCompactionCS::FViewTransmittance>(PassParameters->ViewTransmittanceTexture ? 1 : 0);
+	PermutationVector.Set<FTressFXVisibilityPrimitiveIdCompactionCS::FMaterial>(GTressFXMaterialCompactionEnable ? 1 : 0);
+	PermutationVector.Set<FTressFXVisibilityPrimitiveIdCompactionCS::FPPLL>(bUsePPLL ? PPLLMaxRenderNodePerPixel : 0);
+	PermutationVector.Set<FTressFXVisibilityPrimitiveIdCompactionCS::FVisibility>(bUseVisibility ? 1 : 0);
+	PermutationVector.Set<FTressFXVisibilityPrimitiveIdCompactionCS::FMSAACount>(MSAASampleCount);
+	PermutationVector = FTressFXVisibilityPrimitiveIdCompactionCS::RemapPermutation(PermutationVector);
+
+	PassParameters->OutputResolution = Resolution;
+	PassParameters->VelocityType = VelocityPermutation;
+	PassParameters->MaxNodeCount = MaxRenderNodeCount;
+	PassParameters->bSortSampleByDepth = GTressFXSortHairSampleByDepth > 0 ? 1 : 0;
+	PassParameters->CoverageThreshold = FMath::Clamp(GTressFXFullCoverageThreshold, 0.1f, 1.f);
+	PassParameters->DepthTheshold = FMath::Clamp(GTressFXMaterialCompactionDepthThreshold, 0.f, 100.f);
+	PassParameters->CosTangentThreshold = FMath::Cos(FMath::DegreesToRadians(FMath::Clamp(GTressFXMaterialCompactionTangentThreshold, 0.f, 90.f)));
+	PassParameters->SceneDepthTexture = SceneDepthTexture;
+	PassParameters->ViewUniformBuffer = View.ViewUniformBuffer;
+	PassParameters->OutTressFXOnlyDepthTexture = GraphBuilder.CreateUAV(OutTressFXOnlyDepthTexture);
+	PassParameters->OutCompactNodeCounter = GraphBuilder.CreateUAV(OutCompactCounter);
+	PassParameters->OutCompactNodeIndex = GraphBuilder.CreateUAV(OutCompactNodeIndex);
+	PassParameters->OutCompactNodeData = GraphBuilder.CreateUAV(OutCompactNodeData);
+	PassParameters->OutCompactNodeCoord = GraphBuilder.CreateUAV(OutCompactNodeCoord);
+	PassParameters->OutCategorizationTexture = GraphBuilder.CreateUAV(OutCategorizationTexture);
+
+	if (bWriteOutVelocity)
+	{
+		PassParameters->OutVelocityTexture = GraphBuilder.CreateUAV(OutVelocityTexture);
+	}
+
+	FIntRect TotalRect = ComputeVisibleTressFXMacroGroupsRect(View.ViewRect, MacroGroupDatas);
+
+	// Snap the rect onto thread group boundary
+	const FIntPoint GroupSize = TFXGetVendorOptimalGroupSize2D();
+	TotalRect.Min.X = FMath::FloorToInt(float(TotalRect.Min.X) / float(GroupSize.X)) * GroupSize.X;
+	TotalRect.Min.Y = FMath::FloorToInt(float(TotalRect.Min.Y) / float(GroupSize.Y)) * GroupSize.Y;
+	TotalRect.Max.X = FMath::CeilToInt(float(TotalRect.Max.X) / float(GroupSize.X)) * GroupSize.X;
+	TotalRect.Max.Y = FMath::CeilToInt(float(TotalRect.Max.Y) / float(GroupSize.Y)) * GroupSize.Y;
+
+	FIntPoint RectResolution(TotalRect.Width(), TotalRect.Height());
+	PassParameters->ResolutionOffset = FIntPoint(TotalRect.Min.X, TotalRect.Min.Y);
+
+	const FTressFXTiles::ETileType TileType = FTressFXTiles::ETileType::TfxHairAll;
+	PassParameters->TileCountXY = TileData.TileCountXY;
+	PassParameters->TileSize = FTressFXTiles::TileSize;
+	PassParameters->TileCountBuffer = GraphBuilder.CreateSRV(TileData.TileCountBuffer, PF_R32_UINT);
+	PassParameters->TileDataBuffer = TileData.GetTileBufferSRV(TileType);
+	PassParameters->IndirectBufferArgs = TileData.TileIndirectDispatchBuffer;
+
+	TShaderMapRef<FTressFXVisibilityPrimitiveIdCompactionCS> ComputeShader(View.ShaderMap, PermutationVector);
+	FComputeShaderUtils::AddPass(
+		GraphBuilder,
+		RDG_EVENT_NAME("TressFXVisibilityCompaction"),
+		ERDGPassFlags::Compute /*| ERDGPassFlags::NeverCull*/,
+		ComputeShader,
+		PassParameters,
+		TileData.TileIndirectDispatchBuffer,
+		FTressFXTiles::GetIndirectDispatchArgOffset(TileType));
+
+
+	OutIndirectArgsBuffer = AddCopyIndirectArgPass(GraphBuilder, &View, NodeGroupSize, 1, OutCompactCounter);
+	OutMaxRenderNodeCount = MaxRenderNodeCount;
+}
+
+
+BEGIN_GLOBAL_SHADER_PARAMETER_STRUCT(FVisibilityMaterialPassUniformParametersTFX, )
+	SHADER_PARAMETER(FIntPoint, MaxResolution)
+	SHADER_PARAMETER(uint32, MaxSampleCount)
+	SHADER_PARAMETER(uint32, NodeGroupSize)
+	SHADER_PARAMETER(uint32, bUpdateSampleCoverage)
+	SHADER_PARAMETER(uint32, bOutputEmissive)
+	SHADER_PARAMETER_RDG_TEXTURE(Texture2D<uint>, NodeIndex)
+	SHADER_PARAMETER_RDG_TEXTURE(Texture2D<uint>, TotalNodeCounter)
+	SHADER_PARAMETER_RDG_BUFFER_SRV(StructuredBuffer<uint>, NodeCoord)
+	SHADER_PARAMETER_RDG_BUFFER_SRV(StructuredBuffer<FNodeVisTFX>, NodeVis)
+	SHADER_PARAMETER_RDG_BUFFER_SRV(Buffer<uint>, IndirectArgs)
+	SHADER_PARAMETER_RDG_BUFFER_UAV(RWStructuredBuffer<FPackedTressFXSample>, OutNodeData)
+	SHADER_PARAMETER_RDG_BUFFER_UAV(RWBuffer<float2>, OutNodeVelocity)
+END_GLOBAL_SHADER_PARAMETER_STRUCT()
+
+IMPLEMENT_STATIC_UNIFORM_BUFFER_STRUCT(FVisibilityMaterialPassUniformParametersTFX, "MaterialPassTFXParameters", SceneTextures);
+
+BEGIN_SHADER_PARAMETER_STRUCT(FVisibilityMaterialPassParametersTFX, )
+	SHADER_PARAMETER_STRUCT_REF(FViewUniformShaderParameters, View)
+	SHADER_PARAMETER_STRUCT_INCLUDE(FInstanceCullingDrawParams, InstanceCullingDrawParams)
+	SHADER_PARAMETER_RDG_UNIFORM_BUFFER(FVisibilityMaterialPassUniformParametersTFX, UniformBuffer)
+	RENDER_TARGET_BINDING_SLOTS()
+END_SHADER_PARAMETER_STRUCT()
