+class FTressFXVelocityCS : public FGlobalShader
+{
+	DECLARE_GLOBAL_SHADER(FTressFXVelocityCS);
+	SHADER_USE_PARAMETER_STRUCT(FTressFXVelocityCS, FGlobalShader);
