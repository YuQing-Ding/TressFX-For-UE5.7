+class FMainGroupCullingPrepareIndirectDispatchTFXCS : public FGlobalShader
+{
+	DECLARE_GLOBAL_SHADER(FMainGroupCullingPrepareIndirectDispatchTFXCS);
+	SHADER_USE_PARAMETER_STRUCT(FMainGroupCullingPrepareIndirectDispatchTFXCS, FGlobalShader);
+
+	BEGIN_SHADER_PARAMETER_STRUCT(FParameters, )
+		SHADER_PARAMETER_RDG_BUFFER_UAV(RWBuffer, DrawIndirectBuffer)
+		SHADER_PARAMETER_RDG_BUFFER_UAV(RWBuffer, DispatchIndirectBuffer)
+	END_SHADER_PARAMETER_STRUCT()
+
+public:
+	static bool ShouldCompilePermutation(const FGlobalShaderPermutationParameters& Parameters) { return IsTressFXSupported(ETressFXShaderType::Strands, Parameters.Platform); }
+	static void ModifyCompilationEnvironment(const FGlobalShaderPermutationParameters& Parameters, FShaderCompilerEnvironment& OutEnvironment)
+	{
+		FGlobalShader::ModifyCompilationEnvironment(Parameters, OutEnvironment);
+		OutEnvironment.SetDefine(TEXT("SHADER_PREPAREINDIRECTDISPATCH"), 1);
+	}
+};
+
+IMPLEMENT_GLOBAL_SHADER(FMainGroupCullingPrepareIndirectDispatchTFXCS, "/Engine/Private/TressFX/TressFXGroupCulling.usf", "MainGroupCullingPrepareIndirectDispatchCS", SF_Compute);
+
+
+static void AddGroupCullingPass(
+	FRDGBuilder& GraphBuilder,
+	FGlobalShaderMap* ShaderMap,
+	const FViewInfo& View,
+	const FTressFXCullingParams& CullingParameters,
+	const FTressFXHZBParameters& HZBParameters,
+	FTressFXClusterData::FHairGroup& ClusterData)
+{
+	FRDGImportedBufferTFX DrawIndirectParametersBuffer = Register(GraphBuilder, ClusterData.TressFXGroupPublicPtr->GetDrawIndirectBuffer(), ERDGImportedBufferFlagsTFX::CreateUAV);
+	FRDGImportedBufferTFX DrawIndirectParametersRasterComputeBuffer = Register(GraphBuilder, ClusterData.TressFXGroupPublicPtr->GetDrawIndirectRasterComputeBuffer(), ERDGImportedBufferFlagsTFX::CreateUAV);
+
+	/// Initialise indirect buffers to be setup during the culling process
+	{
+		FTressFXIndBufferClearCS::FParameters* Parameters = GraphBuilder.AllocParameters<FTressFXIndBufferClearCS::FParameters>();
+		//Parameters->DispatchIndirectParametersClusterCount = GraphBuilder.CreateUAV(DispatchIndirectParametersClusterCount);
+		Parameters->DrawIndirectParameters = DrawIndirectParametersBuffer.UAV;
+
+		FTressFXIndBufferClearCS::FPermutationDomain Permutation;
+		Permutation.Set<FTressFXIndBufferClearCS::FSetIndirectDraw>(false);
+		TShaderMapRef<FTressFXIndBufferClearCS> ComputeShader(ShaderMap, Permutation);
+		FComputeShaderUtils::AddPass(
+			GraphBuilder,
+			RDG_EVENT_NAME("BufferClearCS"),
+			ComputeShader,
+			Parameters,
+			FIntVector(1, 1, 1));
+	}
+	
+	/// Generate indirect dispatch and prepare data to expand index buffer
+	{
+		FTressFXGroupCullingCS::FParameters* Parameters = GraphBuilder.AllocParameters<FTressFXGroupCullingCS::FParameters>();
+
+		Parameters->ClusterCount = ClusterData.ClusterCount;
+		Parameters->NumVerticesPerStrand = ClusterData.TressFXGroupPublicPtr->VFInput.Strands.NumVerticesPerStrand;
+		Parameters->CurrentActiveStrandsCount = ClusterData.TressFXGroupPublicPtr->CurrentActiveStrandsCount;
+		
+		Parameters->DrawIndirectParameters = DrawIndirectParametersBuffer.UAV;
+
+		FTressFXGroupCullingCS::FPermutationDomain Permutation;
+		TShaderMapRef<FTressFXGroupCullingCS> ComputeShader(ShaderMap, Permutation);
+		const FIntVector DispatchCount = DispatchCount.DivideAndRoundUp(FIntVector(ClusterData.ClusterCount, 1, 1), FIntVector(64, 1, 1));
+		FComputeShaderUtils::AddPass(
+			GraphBuilder,
+			RDG_EVENT_NAME("GroupCullingCS"),
+			ComputeShader,
+			Parameters,
+			DispatchCount);
+	}
+
+	/// Prepare some indirect dispatch for compute raster visibility buffers
+	{
+		FMainGroupCullingPrepareIndirectDispatchTFXCS::FParameters* Parameters = GraphBuilder.AllocParameters<FMainGroupCullingPrepareIndirectDispatchTFXCS::FParameters>();
+		
+		Parameters->DrawIndirectBuffer = DrawIndirectParametersBuffer.UAV;
+		Parameters->DispatchIndirectBuffer = DrawIndirectParametersRasterComputeBuffer.UAV;
+
+		TShaderMapRef<FMainGroupCullingPrepareIndirectDispatchTFXCS> ComputeShader(ShaderMap);
+		FComputeShaderUtils::AddPass(
+			GraphBuilder,
+			RDG_EVENT_NAME("PrepareIndirectDispatchCS"),
+			ERDGPassFlags::Compute | ERDGPassFlags::NeverCull,
+			ComputeShader,
+			Parameters,
+			FIntVector(1, 1, 1));
+	}
+
+}
+
+void ComputeTressFXGroupCulling(
+	FRDGBuilder& GraphBuilder,
+	FGlobalShaderMap& ShaderMap,
+	const TArray<FViewInfo>& Views,
+	const FTressFXCullingParams& CullingParameters,
+	FTressFXClusterData& ClusterDatas)
+{
+	DECLARE_GPU_STAT(TressFXGroupCulling);
+	RDG_EVENT_SCOPE(GraphBuilder, "TressFXGroupCulling");
+	RDG_GPU_STAT_SCOPE(GraphBuilder, TressFXGroupCulling);
+
+
+	FTressFXHZBParameters HZBParameters;
+
+	const bool bGroupCulling = IsTressFXGroupCullingEnable();
+	for (const FViewInfo& View : Views)
+	{
+		// TODO use compute overlap (will need to split AddClusterCullingPass)
+		//for (FTressFXClusterData::FHairGroup& ClusterData : ClusterDatas.HairGroups)
+		{
+			//AddClusterResetLod0(GraphBuilder, &ShaderMap, ClusterData);
+		}
+
+		if (bGroupCulling)
+		{
+			for (FTressFXClusterData::FHairGroup& ClusterData : ClusterDatas.HairGroups)
+			{
+				AddGroupCullingPass(
+					GraphBuilder,
+					&ShaderMap,
+					View,
+					CullingParameters,
+					HZBParameters,
+					ClusterData);
+			}
+		}
+	}
+
+}
