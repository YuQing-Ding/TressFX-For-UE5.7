+float3 GetVertexPreviousPosition(FVertexFactoryInput Input, bool bInvalidJointVertex = true)
+{
+	FVertexInfo VertexInfo = GetVertexInfo(Input);
+	const float4 PrevPosition = TressFXVF.PreviousPositionBuffer[VertexInfo.VertexIndex];
+	
+	FTressFXControlPoint Out;
+	Out.Position = PrevPosition.xyz;
+	Out.WorldRadius = TressFXVF.Radius * VertexInfo.LodRadiusScale;
+	Out.WorldLength = TressFXVF.LengthBuffer[VertexInfo.BaseIndex];
+	uint Index = VertexInfo.BaseIndex % TressFXVF.NumVerticesPerStrand;
+	uint Type = Index == 0 ? (VertexInfo.IsTip == 0 ? TRESSFX_CONTROLPOINT_START : TRESSFX_CONTROLPOINT_INSIDE) : TRESSFX_CONTROLPOINT_INSIDE;
+	Type = (Index == TressFXVF.NumVerticesPerStrand-1) ? (VertexInfo.IsTip == 0 ? TRESSFX_CONTROLPOINT_END : TRESSFX_CONTROLPOINT_START) : Type;
+	Out.Type = Type;
+
+	// Create a degenerated quad the end of each strand to cut between each strands
+	// #hair_todo: This is not efficient for short strand like fur for instance. Need to revisit that at some point
+	#if RAYHITGROUPSHADER
+	const bool bIsInvalidQuad = false; // can't hit an invalid quad in raytracing (filtered by the acceleration structure)
+	#else
+	const bool bIsInvalidQuad = (bInvalidJointVertex && Out.Type == TRESSFX_CONTROLPOINT_START && VertexInfo.IsTip == 1) || (bInvalidJointVertex && Out.Type == TRESSFX_CONTROLPOINT_END && VertexInfo.IsTip == 0) || VertexInfo.bForceInvalidQuad;
+	#endif
+	Out.Position = bIsInvalidQuad ? float3(INFINITE_FLOAT, INFINITE_FLOAT, INFINITE_FLOAT) : Out.Position;
+
+	return Out.Position;
+}
