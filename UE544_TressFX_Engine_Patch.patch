+class FTressFXVisualizeMTMeshVS : public FGlobalShader
+{
+	DECLARE_GLOBAL_SHADER(FTressFXVisualizeMTMeshVS);
+	SHADER_USE_PARAMETER_STRUCT(FTressFXVisualizeMTMeshVS, FGlobalShader)
+
+	BEGIN_SHADER_PARAMETER_STRUCT(FParameters, )
+		SHADER_PARAMETER_STRUCT_REF(FViewUniformShaderParameters, View)
+		SHADER_PARAMETER_RDG_BUFFER_SRV(StructuredBuffer<float3>, MeshVertexBuffer)
+		SHADER_PARAMETER_RDG_BUFFER_SRV(Buffer<uint>, MeshRestIndicesBuffer)
