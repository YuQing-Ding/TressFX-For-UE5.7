+static float GHairTT = 1;
+static float GHairTRT = 1;
+static float GHairGlobalScattering = 1;
+static float GHairLocalScattering = 1;
+static int32 GHairTTModel = 0;
+static FAutoConsoleVariableRef CVarHairR(TEXT("r.TressFX.Components.R"), GHairR, TEXT("Enable/disable hair BSDF component R"));
+static FAutoConsoleVariableRef CVarHairTT(TEXT("r.TressFX.Components.TT"), GHairTT, TEXT("Enable/disable hair BSDF component TT"));
+static FAutoConsoleVariableRef CVarHairTRT(TEXT("r.TressFX.Components.TRT"), GHairTRT, TEXT("Enable/disable hair BSDF component TRT"));
+static FAutoConsoleVariableRef CVarHairGlobalScattering(TEXT("r.TressFX.Components.GlobalScattering"), GHairGlobalScattering, TEXT("Enable/disable hair BSDF component global scattering"));
+static FAutoConsoleVariableRef CVarHairLocalScattering(TEXT("r.TressFX.Components.LocalScattering"), GHairLocalScattering, TEXT("Enable/disable hair BSDF component local scattering"));
+static FAutoConsoleVariableRef CVarHairTTModel(TEXT("r.TressFX.Components.TTModel"), GHairTTModel, TEXT("Select hair TT model"));
+
+static int32 GTressFXVisibilityRectOptimEnable = 0;
+static FAutoConsoleVariableRef CVarTressFXVisibilityRectOptimEnable(TEXT("r.TressFX.RectLightingOptim"), GTressFXVisibilityRectOptimEnable, TEXT("Hair Visibility use projected view rect to light only relevant pixels"));
+
+
+FTFXHairComponent GetTressFXComponents()
+{
+	FTFXHairComponent Out;
+	Out.R = GHairR > 0;
+	Out.TT = GHairTT > 0;
+	Out.TRT = GHairTRT > 0;
+	Out.LocalScattering = GHairLocalScattering > 0;
+	Out.GlobalScattering = GHairGlobalScattering > 0;
+	Out.TTModel = GHairTTModel > 0 ? 1 : 0;
+	return Out;
+}
+
+uint32 ToBitfield(const FTFXHairComponent& C)
+{
+	return
+		(C.R ? 1u : 0u) |
+		(C.TT ? 1u : 0u) << 1 |
+		(C.TRT ? 1u : 0u) << 2 |
+		(C.LocalScattering ? 1u : 0u) << 3 |
+		(C.GlobalScattering ? 1u : 0u) << 4 |
+		// Multiple scattering         << 5 (used only within shader)
+		(C.TTModel ? 1u : 0u) << 6;
+}
+
+
+static float GTressFXStableRasterizationScale = 1.0f; // For no AA without TAA, a good value is: 1.325f (Empirical)
+static FAutoConsoleVariableRef CVarTressFXStableRasterizationScale(TEXT("r.TressFX.StableRasterizationScale"), GTressFXStableRasterizationScale, TEXT("Rasterization scale to snap strand to pixel for 'stable' hair option. This value can't go below 1."), ECVF_Scalability | ECVF_RenderThreadSafe);
+
+static float GTressFXRasterizationScale = 0.5f; // For no AA without TAA, a good value is: 1.325f (Empirical)
+static FAutoConsoleVariableRef CVarTressFXRasterizationScale(TEXT("r.TressFX.RasterizationScale"), GTressFXRasterizationScale, TEXT("Rasterization scale to snap strand to pixel"), ECVF_Scalability | ECVF_RenderThreadSafe);
+
+static float GTressFXVelocityRasterizationScale = 1.5f; // Tuned based on heavy motion example (e.g., head shaking)
+static FAutoConsoleVariableRef CVarTressFXMaxRasterizationScale(TEXT("r.TressFX.VelocityRasterizationScale"), GTressFXVelocityRasterizationScale, TEXT("Rasterization scale to snap strand to pixel under high velocity"), ECVF_Scalability | ECVF_RenderThreadSafe);
+
+
+float TFXSampleCountToSubPixelSize(uint32 SamplePerPixelCount)
+{
+	float Scale = 1;
+	switch (SamplePerPixelCount)
+	{
+	case 1: Scale = 1.f; break;
+	case 2: Scale = 8.f / 16.f; break;
+	case 4: Scale = 8.f / 16.f; break;
+	case 8: Scale = 4.f / 16.f; break;
+	}
+	return Scale;
+}
+
+FTFXMinHairRadiusAtDepth1 TFXComputeMinStrandRadiusAtDepth1(
+	const FIntPoint& Resolution,
+	const float FOV,
+	const uint32 SampleCount,
+	const float OverrideStrandHairRasterizationScale)
+{
+	auto InternalMinRadiusAtDepth1 = [Resolution, FOV, SampleCount](float RasterizationScale)
+	{
+		const float DiameterToRadius = 0.5f;
+		const float SubPixelScale = TFXSampleCountToSubPixelSize(SampleCount);
+		const float vFOV = FMath::DegreesToRadians(FOV);
+		const float StrandDiameterAtDepth1 = FMath::Tan(vFOV * 0.5f) / (0.5f * Resolution.Y) * SubPixelScale;
+		return DiameterToRadius * RasterizationScale * StrandDiameterAtDepth1;
+	};
+
+	FTFXMinHairRadiusAtDepth1 Out;
+
+	// Scales strand to covers a bit more than a pixel and insure at least one sample point is hit
+	const float PrimaryRasterizationScale = OverrideStrandHairRasterizationScale > 0 ? OverrideStrandHairRasterizationScale : GTressFXRasterizationScale;
+	const float VelocityRasterizationScale = OverrideStrandHairRasterizationScale > 0 ? OverrideStrandHairRasterizationScale : GTressFXVelocityRasterizationScale;
+	const float StableRasterizationScale = FMath::Max(1.f, GTressFXStableRasterizationScale);
+	Out.Primary = InternalMinRadiusAtDepth1(PrimaryRasterizationScale);
+	Out.Velocity = InternalMinRadiusAtDepth1(VelocityRasterizationScale);
+	Out.Stable = InternalMinRadiusAtDepth1(StableRasterizationScale);
+
+	return Out;
+}
+
+FVector4f PackTressFXRenderInfo(
+	float PrimaryRadiusAtDepth1,
+	float StableRadiusAtDepth1,
+	float VelocityRadiusAtDepth1,
+	float VelocityMagnitudeScale)
+{
+	FVector4f Out;
+	Out.X = PrimaryRadiusAtDepth1;
+	Out.Y = StableRadiusAtDepth1;
+	Out.Z = VelocityRadiusAtDepth1;
+	Out.W = VelocityMagnitudeScale;
+	return Out;
+}
+
+uint32 PackTressFXRenderInfoBits(
+	bool  bIsOrtho,
+	bool  bIsGPUDriven)
+{
+	uint32 BitField = 0;
+	BitField |= bIsOrtho ? 0x1 : 0;
+	BitField |= bIsGPUDriven ? 0x2 : 0;
+	return BitField;
+}
+
+static int32 GTressFXComposeAfterTranslucency = 1;
+static FAutoConsoleVariableRef CVarTressFXComposeAfterTranslucency(TEXT("r.TressFX.ComposeAfterTranslucency"), GTressFXComposeAfterTranslucency, TEXT("Compose TressFX rendering with scene color after the translucency pass if true. Otherwise compose hair defor the translucent objects are rendered."));
