+FTressFXControlPoint GetVertexPosition(FVertexFactoryInput Input, bool bInvalidJointVertex=true)
+{
+	const FVertexInfo VertexInfo = GetVertexInfo(Input);
+	return GetVertexPosition(VertexInfo, bInvalidJointVertex);
