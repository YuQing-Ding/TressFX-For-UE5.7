+// AMD TressFX BEGIN
+void FDeferredShadingSceneRenderer::RenderDeferredReflectionsAndSkyLightingTressFX(FRDGBuilder& GraphBuilder)
+{
+	if (ViewFamily.EngineShowFlags.VisualizeLightCulling || !ViewFamily.EngineShowFlags.Lighting)
+	{
+		return;
+	}
+
+	uint32 CurrentViewIndex = 0;
+	for (FViewInfo& View : Views)
+	{
+		// if we are rendering a reflection capture then we can skip this pass entirely (no reflection and no sky contribution evaluated in this pass)
+		if (View.bIsReflectionCapture)
+		{
+			++CurrentViewIndex;
+			continue;
+		}
+
+		const bool bSkyLight = Scene->SkyLight
+			&& (Scene->SkyLight->ProcessedTexture || Scene->SkyLight->bRealTimeCaptureEnabled)
+			&& !Scene->SkyLight->bHasStaticLighting;
+
+		bool bDynamicSkyLight = ShouldRenderDeferredDynamicSkyLight(Scene, ViewFamily);
+
+		const bool bReflectionEnv = ShouldDoReflectionEnvironment(Scene, ViewFamily);
+
+		const bool bIsTressFXSkyLightingEnabled = HasViewTressFXData(View) && (bSkyLight || bDynamicSkyLight || bReflectionEnv);
+		if (bIsTressFXSkyLightingEnabled)
+		{
+			//RDG_GPU_STAT_SCOPE(GraphBuilder, TressFXSkyLighting);
+			RenderTressFXEnvironmentLighting(GraphBuilder, Scene, View);
+		}
+		++CurrentViewIndex;
+	}
+}
