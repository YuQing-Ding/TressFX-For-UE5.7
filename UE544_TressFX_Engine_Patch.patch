+extern TTressFXVisualizeMeshFunction GTressFXVisualizeMeshFunction;
+
+static void AddTressFXVisualizeSDFMeshPass(
+	FRDGBuilder& GraphBuilder,
+	const FScene* Scene,
+	const FViewInfo& View,
+	FRDGTextureRef& InSceneColorTexture,
+	FRDGTextureRef& InSceneDepthTexture)
+{
+	if (!GTressFXVisualizeMeshFunction)
+		return;
+
+	FTressFXVisualizeMeshParameters VisualizeSDFMeshParameters;
+	VisualizeSDFMeshParameters.WorldType = Scene->GetWorld()->WorldType;
+	VisualizeSDFMeshParameters.WorldName = Scene->GetWorld()->GetName();
+
+	GTressFXVisualizeMeshFunction(GraphBuilder, VisualizeSDFMeshParameters);
+
+	if (0 == VisualizeSDFMeshParameters.IndicesCount)
+		return;
+
+	uint32 NumIndices = VisualizeSDFMeshParameters.IndicesCount;
+	uint32 NumTriangles = NumIndices / 3;
+	uint32 NumVertices = VisualizeSDFMeshParameters.VertexCount;
+	FBufferRHIRef IndexBuffer = VisualizeSDFMeshParameters.IndicesBufferRHI;
+
+	TShaderMapRef<FTressFXVisualizeSDFMeshVS> VertexShader(View.ShaderMap);
+	TShaderMapRef<FTressFXVisualizeSDFMeshPS> PixelShader(View.ShaderMap);
+	const FGlobalShaderMap* GlobalShaderMap = View.ShaderMap;
+	const FIntRect Viewport = View.ViewRect;
+
+	FTressFXVisualizeSDFMeshVS::FParameters* Parameters = GraphBuilder.AllocParameters<FTressFXVisualizeSDFMeshVS::FParameters>();
+	Parameters->View = View.ViewUniformBuffer;
+	Parameters->MeshVertexBuffer = VisualizeSDFMeshParameters.MeshVertexBuffer;
+	Parameters->RenderTargets[0] = FRenderTargetBinding(InSceneColorTexture, ERenderTargetLoadAction::ELoad, 0);
+	Parameters->RenderTargets.DepthStencil = FDepthStencilBinding(
+		InSceneDepthTexture,
+		ERenderTargetLoadAction::ELoad,
+		ERenderTargetLoadAction::ENoAction,
+		FExclusiveDepthStencil::DepthWrite_StencilNop);
+
+	{
+		ClearUnusedGraphResources(VertexShader, Parameters);
+
+		GraphBuilder.AddPass(
+			RDG_EVENT_NAME("TressFXVisualizeSDFMesh"),
+			Parameters,
+			ERDGPassFlags::Raster | ERDGPassFlags::NeverCull,
+			[Parameters, IndexBuffer, NumTriangles, NumVertices, VertexShader, PixelShader, Viewport](FRHICommandList& RHICmdList)
+			{
+				FGraphicsPipelineStateInitializer GraphicsPSOInit;
+				RHICmdList.ApplyCachedRenderTargets(GraphicsPSOInit);
+				GraphicsPSOInit.BlendState = TStaticBlendState<CW_RGBA, BO_Add, BF_One, BF_Zero, BO_Add, BF_One, BF_Zero>::GetRHI();
+				GraphicsPSOInit.RasterizerState = TStaticRasterizerState<FM_Wireframe, CM_None>::GetRHI();
+				GraphicsPSOInit.DepthStencilState = TStaticDepthStencilState<true, CF_GreaterEqual>::GetRHI();
+
+				GraphicsPSOInit.BoundShaderState.VertexDeclarationRHI = GFilterVertexDeclaration.VertexDeclarationRHI;
+				GraphicsPSOInit.BoundShaderState.VertexShaderRHI = VertexShader.GetVertexShader();
+				GraphicsPSOInit.BoundShaderState.PixelShaderRHI = PixelShader.GetPixelShader();
+				GraphicsPSOInit.PrimitiveType = PT_TriangleList;
+				SetGraphicsPipelineState(RHICmdList, GraphicsPSOInit, 0);
+
+				SetShaderParameters(RHICmdList, VertexShader, VertexShader.GetVertexShader(), *Parameters);
+
+				{
+					RHICmdList.SetViewport(Viewport.Min.X, Viewport.Min.Y, 0.0f, Viewport.Max.X, Viewport.Max.Y, 1.0f);
+					
+					RHICmdList.DrawIndexedPrimitive(IndexBuffer, 0, 0, NumVertices, 0, NumTriangles, 1);
+				}
+			});
+	}
+}
