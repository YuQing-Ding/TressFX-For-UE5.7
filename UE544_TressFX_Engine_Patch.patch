+template<ETressFXVisibilityRenderMode RenderMode>
+class FTressFXVisibilityPS : public FMeshMaterialShader
+{
+	DECLARE_SHADER_TYPE(FTressFXVisibilityPS, MeshMaterial);
+
+public:
+
+	FTressFXVisibilityPS(const ShaderMetaType::CompiledShaderInitializerType& Initializer)
+		: FMeshMaterialShader(Initializer)
+	{
+		ERHIFeatureLevel::Type FeatureLevel = GetMaxSupportedFeatureLevel((EShaderPlatform)Initializer.Target.Platform);
+		check(FSceneInterface::GetShadingPath(FeatureLevel) != EShadingPath::Mobile);
+		TressFXVisibilityPass_HairMacroGroupIndex.Bind(Initializer.ParameterMap, TEXT("TressFXVisibilityPass_HairMacroGroupIndex"));
+		TressFXVisibilityPass_HairMaterialId.Bind(Initializer.ParameterMap, TEXT("TressFXVisibilityPass_HairMaterialId"));
+		TressFXVisibilityPass_LightChannelMask.Bind(Initializer.ParameterMap, TEXT("TressFXVisibilityPass_LightChannelMask"));
+	}
+
+	FTressFXVisibilityPS() {}
+
+	static bool ShouldCompilePermutation(const FMeshMaterialShaderPermutationParameters& Parameters)
+	{
+		if (Parameters.VertexFactoryType->GetFName() != FName(TEXT("FTressFXVertexFactory")))
+		{
+			return false;
+		}
+
+		// Disable PPLL rendering for non-PC platform
+		if (RenderMode == TressFXVisibilityRenderMode_PPLL)
+		{
+			return IsCompatibleWithTressFX(Parameters.Platform, Parameters.MaterialParameters) && IsPCPlatform(Parameters.Platform) && !IsMobilePlatform(Parameters.Platform);
+		}
+		else
+		{
+			return IsCompatibleWithTressFX(Parameters.Platform, Parameters.MaterialParameters);
+		}
+	}
+
+	static void ModifyCompilationEnvironment(const FMaterialShaderPermutationParameters& Parameters, FShaderCompilerEnvironment& OutEnvironment)
+	{
+		FMaterialShader::ModifyCompilationEnvironment(Parameters, OutEnvironment);
+		const uint32 RenderModeValue = uint32(RenderMode);
+		OutEnvironment.SetDefine(TEXT("HAIR_RENDER_MODE"), RenderModeValue);
+
+		if (RenderMode == TressFXVisibilityRenderMode_MSAA_Visibility)
+		{
+			OutEnvironment.SetRenderTargetOutputFormat(0, PF_R32_UINT);
+		}
+		else if (RenderMode == TressFXVisibilityRenderMode_MSAA)
+		{
+			OutEnvironment.SetRenderTargetOutputFormat(0, PF_R32G32_UINT);
+			OutEnvironment.SetRenderTargetOutputFormat(1, PF_R32G32_UINT);
+			OutEnvironment.SetRenderTargetOutputFormat(2, PF_R32G32_UINT);
+		}
+		else if (RenderMode == TressFXVisibilityRenderMode_Transmittance)
+		{
+			OutEnvironment.SetRenderTargetOutputFormat(0, PF_R32_FLOAT);
+		}
+	}
+
+	void GetShaderBindings(
+		const FScene* Scene,
+		ERHIFeatureLevel::Type FeatureLevel,
+		const FPrimitiveSceneProxy* PrimitiveSceneProxy,
+		const FMaterialRenderProxy& MaterialRenderProxy,
+		const FMaterial& Material,
+		//const FMeshPassProcessorRenderState& DrawRenderState,
+		const FTressFXVisibilityShaderElementData& ShaderElementData,
+		FMeshDrawSingleShaderBindings& ShaderBindings) const
+	{
+		FMeshMaterialShader::GetShaderBindings(Scene, FeatureLevel, PrimitiveSceneProxy, MaterialRenderProxy, Material, ShaderElementData, ShaderBindings);
+		ShaderBindings.Add(TressFXVisibilityPass_HairMacroGroupIndex, ShaderElementData.HairMacroGroupId);
+		ShaderBindings.Add(TressFXVisibilityPass_HairMaterialId, ShaderElementData.HairMaterialId);
+		ShaderBindings.Add(TressFXVisibilityPass_LightChannelMask, ShaderElementData.LightChannelMask);
+	}
+
+	LAYOUT_FIELD(FShaderParameter, TressFXVisibilityPass_HairMacroGroupIndex);
+	LAYOUT_FIELD(FShaderParameter, TressFXVisibilityPass_HairMaterialId);
+	LAYOUT_FIELD(FShaderParameter, TressFXVisibilityPass_LightChannelMask);
+};
