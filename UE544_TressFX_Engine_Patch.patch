+
+#include "../Common.ush"
+
+//-----------Collision Mesh-------------------
+
+struct FTressFXMeshVertexData
+{
+	float4 Position;
+	float4 Normal;
+};
+StructuredBuffer<FTressFXMeshVertexData>		MeshVertexBuffer;
+
+struct FTressFXVisualizeSDFMeshVSToPS
+{
+	float4 SvPosition : SV_POSITION;
+	float4 Color : TEXCOORD0;
+};
+
+void MeshMainVS(
+	uint VertexID : SV_VertexID,
+	out FTressFXVisualizeSDFMeshVSToPS Output)
+{
+	ResolvedView = ResolveView();
+
+	float3 VertexPosition = MeshVertexBuffer[VertexID].Position.xyz;
+	const float4 TranslatedWorldPosition = float4(VertexPosition.xyz + LWCToFloat(ResolvedView.PreViewTranslation).xyz,1);
+
+	Output.SvPosition = mul(TranslatedWorldPosition, View.TranslatedWorldToClip);
+	
+	Output.Color = float4(0,1,1,0);
+}
+
+void MeshMainPS(
+	FTressFXVisualizeSDFMeshVSToPS Input,
+	out float4 OutColor : SV_Target0
+	)
+{
+	//
+	OutColor = Input.Color;
+}
+
+//----------Collision Mesh AABB-------------
+
+struct FCollisionMeshBox
+{
+	float4 Min;
+	float4 Max;
+	float4 CellSize;
+};
+StructuredBuffer<FCollisionMeshBox> CMBoxBuffer;
+
+struct FTressFXVisualizeSDFMeshAABBMSToPS
+{
+	float4 SvPosition : SV_POSITION;
+	float4 Color : TEXCOORD0;
+};
+
+
+static const int3 kOffsets[8] =
+{
+	int3(-1, -1, -1),
+	int3(1, -1, -1),
+	int3(1, 1, -1),
+	int3(-1, 1, -1),
+	int3(-1, -1, 1),
+	int3(1, -1, 1),
+	int3(1, 1, 1),
+	int3(-1, 1, 1),
+};
+
+static const uint2 kIndices[13] =
+{
+	uint2(0, 1),
+	uint2(1, 2),
+	uint2(2, 3),
+	uint2(3, 0),
+	uint2(4, 5),
+	uint2(5, 6),
+	uint2(6, 7),
+	uint2(7, 4),
+	uint2(0, 4),
+	uint2(1, 5),
+	uint2(2, 6),
+	uint2(3, 7),
+	uint2(8, 9),
+};
+
+[numthreads(64, 1, 1)]
+[outputtopology("line")]
+void MeshAABBMainMS(
+	uint GroupThreadID : SV_GroupThreadID,
+	uint GroupID : SV_GroupID, 
+	out vertices FTressFXVisualizeSDFMeshAABBMSToPS OutVertices[8],
+	out indices uint2 OutLines[12]
+)
+{
+	ResolvedView = ResolveView();
+
+    // Set number of outputs
+    SetMeshOutputCounts(8, 12);
+
+	FCollisionMeshBox MeshBox = CMBoxBuffer[0];
+	float3 VoxelCenter = (MeshBox.Min.xyz+MeshBox.Max.xyz)*0.5f*100.f;
+	VoxelCenter += LWCToFloat(ResolvedView.PreViewTranslation).xyz;
+	float3 Step = 0.5f*(MeshBox.Max.xyz-MeshBox.Min.xyz)*100.f;
+
+	if(GroupThreadID < 8)
+	{
+		OutVertices[GroupThreadID].SvPosition = mul(float4(VoxelCenter + Step*kOffsets[GroupThreadID],1),View.TranslatedWorldToClip);
+		OutVertices[GroupThreadID].Color = float4(1.f,1.f,1.f,1.f);
+	}
+
+	if(GroupThreadID < 12)
+	{
+		OutLines[GroupThreadID] = kIndices[GroupThreadID];
+	}
+
+}
+
+void MeshAABBMainPS(
+	FTressFXVisualizeSDFMeshAABBMSToPS Input,
+	out float4 OutColor : SV_Target0
+	)
+{
+	//
+	OutColor = Input.Color;
+}
+
+
+//----------SDF--------------------
+
+int3 NumSDFCells;
+uint PointOffset;
+
+StructuredBuffer<uint> SDFBufferR;
+
+StructuredBuffer<uint> SDFDirectionStartOffsetBufferR;
+
+struct FDirectionAndCellIndex
+{
+	float3 Direction;
+	float Distance;
+	uint CellIndex;
+	uint Next;
+};
+StructuredBuffer<FDirectionAndCellIndex> SDFDirectionBufferR;
+
+
+struct FTressFXVisualizeSDFMSToPS
+{
+	float4 SvPosition : SV_POSITION;
+	float4 Color : TEXCOORD0;
+};
+
+
+[numthreads(64, 1, 1)]
+[outputtopology("line")]
+void SDFMainMS(
+	uint GroupThreadID : SV_GroupThreadID,
+	uint GroupID : SV_GroupID, 
+	out vertices FTressFXVisualizeSDFMeshAABBMSToPS OutVertices[10],
+	out indices uint2 OutLines[13]
+)
+{
+	ResolvedView = ResolveView();
+	
+    // Set number of outputs
+    SetMeshOutputCounts(10, 13);
+
+	uint VertexID = GroupID + PointOffset;
+	
+	float Distance = asfloat(SDFBufferR[VertexID]);
+
+	if(Distance == 1e10f)
+	{
+		return ;
+	}
+	
+	uint X = VertexID % NumSDFCells.x;
+	uint Y = VertexID % (NumSDFCells.x*NumSDFCells.y) / NumSDFCells.x;
+	uint Z = VertexID / (NumSDFCells.x*NumSDFCells.y);
+	
+	FCollisionMeshBox MeshBox = CMBoxBuffer[0];
+
+	float3 Step = 0.5*MeshBox.CellSize.xyz*100.f;
+
+	float3 VoxelCenter = (MeshBox.Min.xyz + float3(X,Y,Z)*MeshBox.CellSize.xyz)*100.f+Step;
+	VoxelCenter += LWCToFloat(ResolvedView.PreViewTranslation).xyz;
+	
+	float4 Pt[2];
+
+	Distance *= 100.f;
+
+	uint Offset = SDFDirectionStartOffsetBufferR[VertexID];
+	float3 Dir = -SDFDirectionBufferR[Offset].Direction;
+
+	float Dist = Distance > 0 ? Distance : -Distance;
+
+	Pt[0] = mul(float4(VoxelCenter,1),View.TranslatedWorldToClip);
+	Pt[1] = mul(float4(VoxelCenter+Dist*Dir,1),View.TranslatedWorldToClip);
+
+	if(GroupThreadID < 8)
+	{
+		OutVertices[GroupThreadID].SvPosition = mul(float4(VoxelCenter + Step*kOffsets[GroupThreadID],1), View.TranslatedWorldToClip);
+		OutVertices[GroupThreadID].Color = float4(1.f,1.f,0,1.f);
+	}
+	else if(GroupThreadID < 10)
+	{
+		OutVertices[GroupThreadID].SvPosition = Pt[GroupThreadID - 8];
+		float4 Color;
+		if(Distance < 0)
+			Color = float4(1,0,0,1);
+		else
+			Color = float4(0,0,1,1);
+		OutVertices[GroupThreadID].Color = Color;
+	}
+	
+	if(GroupThreadID < 13)
+	{
+		OutLines[GroupThreadID] = kIndices[GroupThreadID];
+	}
+}
+
+void SDFMainPS(
+	FTressFXVisualizeSDFMSToPS Input,
+	out float4 OutColor : SV_Target0
+	)
+{
+	//
+	OutColor = Input.Color;
+}
